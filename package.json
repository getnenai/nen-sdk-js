{
  "name": "nen-sdk-js",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Nen Desktop API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "tsup": "^8.0",
    "typescript": "^5.9",
    "vitest": "^3.0"
  },
  "license": "MIT"
}
